{
  "name": "pokedex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "data:fetch": "node scripts/fetch-pokemon.mjs",
    "data:zh": "node scripts/patch-zh-names.mjs",
    "data:abilities": "node scripts/patch-abilities.mjs",
    "data:tiers": "node scripts/patch-tiers.mjs",
    "data:analyses": "node scripts/fetch-analyses.mjs",
    "data:all": "node scripts/fetch-pokemon.mjs && node scripts/patch-zh-names.mjs && node scripts/patch-abilities.mjs && node scripts/patch-tiers.mjs"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
